{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Nettify Hjelp",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guider",
        "groups": [
          {
            "group": "Kom i gang",
            "pages": ["index", "kom-i-gang"]
          },
          {
            "group": "Nettify AI",
            "pages": [
              "ai/snakk-med-ai",
              "ai/lag-ny-seksjon",
              "ai/endre-bilder",
              "ai/endre-tekst",
              "ai/lag-ny-side",
              "ai/html-widget",
              "ai/booking-modal",
              "ai/kontakt-modal",
              "ai/oversettelse",
              "ai/smarte-funksjoner"
            ]
          },
          {
            "group": "Manuell redigering",
            "pages": [
              "redigering/manuell-editor",
              "redigering/endre-tekst-og-innhold",
              "redigering/endre-farger-og-design",
              "redigering/endre-bilder-manuelt",
              "redigering/endre-spacing-og-storrelse"
            ]
          },
          {
            "group": "Domene",
            "pages": ["domene/kjop-domene", "domene/koble-til-domene"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Nettify.no",
          "href": "https://nettify.no",
          "icon": "globe"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png",
    "height": 35
  },
  "navbar": {
    "links": [
      {
        "label": "Kontakt oss",
        "href": "mailto:support@nettify.no"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Tilbake til Nettify",
      "href": "https://nettify.no/dashboard/"
    }
  },
  "footer": {
    "socials": {
      "facebook": "https://www.facebook.com/nettify.no",
      "instagram": "https://www.instagram.com/nettify.no/",
      "linkedin": "https://www.linkedin.com/company/nettifyno/"
    }
  }
}
